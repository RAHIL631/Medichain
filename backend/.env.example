# medichain/backend/.env.example
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/medichain

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_minimum_32_chars_long

# ── Pinata IPFS Storage ───────────────────────────────────────────────────────
# Get credentials at: https://app.pinata.cloud/keys → "New Key"
#
# RECOMMENDED — use JWT (supports Pinata V2 API, single token):
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_jwt_here
#
# LEGACY FALLBACK — classic API Key + Secret (Pinata V1):
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here
#
# Gateway — use "gateway.pinata.cloud" or your dedicated Pinata subdomain:
PINATA_GATEWAY=gateway.pinata.cloud

# ── AI Microservice ───────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:5001

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
