# ai/.dockerignore
# Files excluded from the Docker build context.
# Keeps the image small and avoids accidentally including secrets or large files.

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/
.env.local

# Development / IDE
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Large data files (mount as volume instead)
data/*.csv

# Test artifacts
.pytest_cache/
htmlcov/
.coverage
*.cover

# Logs
*.log
logs/

# Model plot artifacts (regenerated during training)
models/plots/

# Documentation
*.md
docs/

# Node (if any frontend assets)
node_modules/
