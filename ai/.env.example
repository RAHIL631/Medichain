# ai/.env.example
# MediChain AI Microservice — Environment Variable Template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5001
FLASK_ENV=development       # "development" | "production"
DEBUG=false                 # true only in development

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ── CORS (comma-separated list of allowed origins) ────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3005,http://localhost:3006,http://localhost:5000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text             # "text" (dev) | "json" (production/Datadog/ELK)

# ── Paths (defaults are relative to ai/ — override if running from different CWD)
# MODEL_DIR=/absolute/path/to/models
# DATA_DIR=/absolute/path/to/data
# VERSION_MANIFEST=/absolute/path/to/models_registry/version_manifest.json

# ── Model Loading ─────────────────────────────────────────────────────────────
# Comma-separated list of diseases to load (default: all)
ENABLED_DISEASES=heart,diabetes,stroke,kidney,liver,adherence

# Set to true to crash on startup if any model file is missing
STRICT_MODEL_LOADING=false

# ── External APIs ─────────────────────────────────────────────────────────────
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov/REST
RXNORM_TIMEOUT=8

# ── Request ───────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=120     # set high for OCR pipeline

# ── Gunicorn (production only) ────────────────────────────────────────────────
GUNICORN_WORKERS=5              # override auto-calculated (2*cores)+1
GUNICORN_TIMEOUT=120

# ── Service Metadata ──────────────────────────────────────────────────────────
SERVICE_NAME=medichain-ai
SERVICE_VERSION=3.0.0
